# Frontend (Vite) – baked in at build time. For production, set these in your host/build env.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# Backend (Express) – separate from frontend. Use .env.local for local dev; in production
# set DATABASE_URL, PORT, GOOGLE_* etc. in your backend host (Railway, Render, etc.).
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# PORT=4000

# Supabase (for proxying fetch-price / fetch-financials from backend). If unset, backend falls back to VITE_* from env.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Drive upload (optional) – see docs/GOOGLE_DRIVE_SETUP.md
# GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id  (folder in My Drive or Shared Drive)

# Option A: OAuth (personal Gmail – no Workspace needed). User signs in once via "Connect Google Drive".
# GOOGLE_OAUTH_CLIENT_JSON_PATH=./backend/secrets/client_secret_xxx.json
# FRONTEND_URL=http://localhost:8080
# BACKEND_URL=http://localhost:4000

# Option B: Service account (for Shared Drive / Google Workspace)
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./backend/secrets/drive-sa.json
# Or: GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Set to false to keep local PDFs after uploading to Drive (default: delete locally after upload)
# DELETE_LOCAL_AFTER_DRIVE_UPLOAD=false

# Screener.in (for Express financials fetch – company page scraping)
# SCREENER_SESSION_ID=your_session_cookie_value
# SCREENER_CSRF_TOKEN=your_csrf_token_value

